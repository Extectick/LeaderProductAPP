# syntax=docker/dockerfile:1.7
FROM node:20-alpine AS build

WORKDIR /app
COPY package.json package-lock.json ./
COPY scripts ./scripts
RUN --mount=type=cache,target=/root/.npm \
    for attempt in 1 2 3 4 5; do \
      npm ci --prefer-offline && break; \
      if [ "$attempt" = "5" ]; then exit 1; fi; \
      sleep 10; \
    done

COPY . .

ARG EXPO_PUBLIC_API_URL_DEV
ARG EXPO_PUBLIC_TELEGRAM_BOT_USERNAME
ENV EXPO_PUBLIC_API_URL_DEV=${EXPO_PUBLIC_API_URL_DEV}
ENV EXPO_PUBLIC_TELEGRAM_BOT_USERNAME=${EXPO_PUBLIC_TELEGRAM_BOT_USERNAME}

RUN npm run build:web

FROM nginx:alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
